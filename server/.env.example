# ==============================================
# RealEnhance Server Environment Configuration
# ==============================================

# -----------------
# Node Environment
# -----------------
NODE_ENV=development
PORT=5000

# -----------------
# CORS Configuration
# -----------------
# Comma-separated list of allowed client origins
# IMPORTANT: Must include production client URL to avoid CORS errors
PUBLIC_ORIGIN=http://localhost:5173,http://localhost:5000

# For production:
# PUBLIC_ORIGIN=https://client-production-3021.up.railway.app

# -----------------
# Client URL
# -----------------
# Used for Stripe checkout redirects and agency invite emails
# CRITICAL: Must be set to production URL in Railway for invite links to work
CLIENT_URL=http://localhost:5173

# For production:
# CLIENT_URL=https://client-production-3021.up.railway.app

# -----------------
# Session Configuration
# -----------------
# Generate a random secret: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-random-secret-string-in-production

# -----------------
# Redis
# -----------------
# Required for session storage in production
REDIS_URL=redis://localhost:6379

# Railway provides REDIS_PRIVATE_URL automatically when Redis is attached
# REDIS_PRIVATE_URL is preferred over REDIS_URL for internal connections

# -----------------
# Stripe API Keys
# -----------------
# Get these from: https://dashboard.stripe.com/apikeys
# Test mode keys (for development)
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Production keys (for deployment)
# STRIPE_SECRET_KEY=sk_live_your_live_key_here
# STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here

# Webhook secret for verifying Stripe webhook events
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (NZD active)
STRIPE_PRICE_STARTER=price_your_starter_nzd_price_id
STRIPE_PRICE_PRO=price_your_pro_nzd_price_id
STRIPE_PRICE_AGENCY=price_your_agency_nzd_price_id

# Stripe Add-on Price IDs (NZD active)
STRIPE_ADDON_SMALL=price_your_small_addon_nzd_price_id
STRIPE_ADDON_STANDARD=price_your_standard_addon_nzd_price_id
STRIPE_ADDON_LARGE=price_your_large_addon_nzd_price_id

# Stripe One-Off Pack Price IDs (NZD active)
# Preferred new naming for no-subscription packs
STRIPE_PRICE_HERO_PACK=price_your_hero_pack_nzd_price_id
STRIPE_PRICE_LISTING_PACK_20=price_your_listing_pack_20_nzd_price_id

# Optional Product IDs (for dashboard/reference consistency)
# STRIPE_PRODUCT_HERO_PACK=prod_your_hero_pack_product_id
# STRIPE_PRODUCT_LISTING_PACK=prod_your_listing_pack_product_id

# Legacy compatibility (optional)
# Existing deployments may still use this key for listing pack.
# If STRIPE_PRICE_LISTING_PACK_20 is unset, server falls back to STRIPE_LISTING_PACK.
# STRIPE_LISTING_PACK=price_legacy_listing_pack_price_id

# Optional future AUD Price IDs
# STRIPE_PRICE_STARTER_AUD=price_your_starter_aud_price_id
# STRIPE_PRICE_PRO_AUD=price_your_pro_aud_price_id
# STRIPE_PRICE_AGENCY_AUD=price_your_agency_aud_price_id
# STRIPE_ADDON_SMALL_AUD=price_your_small_addon_aud_price_id
# STRIPE_ADDON_STANDARD_AUD=price_your_standard_addon_aud_price_id
# STRIPE_ADDON_LARGE_AUD=price_your_large_addon_aud_price_id

# Optional: Override Stripe API version (defaults to SDK version)
# STRIPE_API_VERSION=2024-04-10

# -----------------
# Google OAuth
# -----------------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# For production:
# GOOGLE_CALLBACK_URL=https://server-production-96f7.up.railway.app/auth/google/callback

# -----------------
# Gemini AI (Auto Failure Analysis)
# -----------------
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_ANALYSIS=gemini-2.5-flash-exp
STRUCTURAL_INVARIANT_MODEL=gemini-2.5-flash
ANALYSIS_ENABLED=true
ANALYSIS_RUN_ON_FAILURE=true
ANALYSIS_MAX_IMAGES=3
ANALYSIS_TIMEOUT_MS=30000
ANALYSIS_REDACT=true

# -----------------
# SendGrid Email Service
# -----------------
# Get your API key from: https://app.sendgrid.com/settings/api_keys
# Create a "Restricted Access" key with "Mail Send" → "Full Access" permission
# Free tier: 100 emails/day
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# SendGrid Dynamic Templates (Optional - enables branded email template)
# Set to '1' or 'true' to use dynamic templates for all email notifications
# When disabled, falls back to plain HTML emails with inline styling
SENDGRID_USE_TEMPLATES=1

# Get template ID from: https://mc.sendgrid.com/dynamic-templates
# Template must include these Handlebars fields:
# - notification_type, heading, greeting, body_text, cta_text, cta_url, footer_text, additional_info
SENDGRID_TEMPLATE_ID=d-your_template_id_here

# -----------------
# AWS S3 (Image Storage)
# -----------------
# Required in production for image uploads
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=your-bucket-name

# -----------------
# Credits (Optional)
# -----------------
# Enable credit-based billing system
# CREDITS_ENABLED=1

# -----------------
# Monthly Promo Top-Up (Optional)
# -----------------
# Automatically attempts to redeem a promo code monthly for specific user emails.
# Intended for manual support/pilot accounts that should receive recurring top-ups.
#
# Comma-separated list of user emails to target (for example, exactly two users).
# MONTHLY_TOPUP_PROMO_USER_EMAILS=user1@example.com,user2@example.com
#
# Promo code to redeem for those users (default: AdminUserMonthlyTopUp200).
# MONTHLY_TOPUP_PROMO_CODE=AdminUserMonthlyTopUp200
#
# Scheduler interval in milliseconds (default: 21600000 = 6 hours).
# MONTHLY_TOPUP_PROMO_INTERVAL_MS=21600000
