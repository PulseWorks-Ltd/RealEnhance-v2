{
  "services": [
    {
      "name": "server",
      "builder": "NIXPACKS",
      "rootDirectory": ".",
      "watchPatterns": [
        "server/**",
        "shared/**",
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "railway.json"
      ],
      "buildCommand": "NODE_ENV=development pnpm install --no-frozen-lockfile --prefer-offline && NODE_ENV=development pnpm --filter @realenhance/shared run build && NODE_ENV=development pnpm --filter @realenhance/server run build",
      "startCommand": "pnpm --filter @realenhance/server run start",
      "deploy": {
        "releaseCommand": "pnpm --filter @realenhance/server exec node dist/db/migrate.js"
      }
    },
    {
      "name": "worker",
      "builder": "NIXPACKS",
      "rootDirectory": ".",
      "watchPatterns": [
        "worker/**",
        "shared/**",
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "railway.json"
      ],
      "buildCommand": "NODE_ENV=development pnpm install --no-frozen-lockfile --prefer-offline && NODE_ENV=development pnpm --filter @realenhance/shared run build && NODE_ENV=development pnpm --filter @realenhance/worker run build",
      "startCommand": "pnpm --filter @realenhance/worker run start"
    },
    {
      "name": "client",
      "builder": "NIXPACKS",
      "rootDirectory": "client",
      "watchPatterns": [
        "client/**",
        "shared/**",
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "railway.json"
      ],
      "buildCommand": "pnpm install --no-frozen-lockfile --prefer-offline && pnpm run build",
      "startCommand": "pnpm run start"
    }
  ]
}
