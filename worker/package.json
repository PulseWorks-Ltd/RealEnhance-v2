{
  "name": "@realenhance/worker",
  "version": "1.0.0",
  "private": true,
  "main": "dist/worker/src/worker.js",
  "types": "dist/worker/src/worker.d.ts",
  "scripts": {
    "dev": "NODE_ENV=development tsx src/worker.ts",
    "dev:vertex-experimental": "NODE_ENV=development tsx src/vertexExperimentalWorker.ts",
    "build": "pnpm --filter @realenhance/shared run build && tsc -p tsconfig.json",
    "prestart": "pnpm run build",
    "start": "NODE_ENV=production node dist/worker/src/worker.js",
    "start:vertex-experimental": "NODE_ENV=production node dist/worker/src/vertexExperimentalWorker.js",
    "test": "jest --config jest.config.cjs --no-coverage",
    "test:guard:multizone": "tsx src/scripts/assert-multizone-full-mode.ts",
    "test:furnished-gate": "tsx src/scripts/test-furnished-gate.ts",
    "test:opening-occlusion-gate": "tsx src/scripts/test-opening-occlusion-gate.ts",
    "test:opening-regression-fixtures": "tsx src/scripts/run-opening-regression-fixtures.ts --mode snapshot",
    "test:opening-regression-fixtures:ci": "tsx src/scripts/run-opening-regression-fixtures.ts --mode snapshot",
    "test:opening-regression-fixtures:live": "tsx src/scripts/run-opening-regression-fixtures.ts --mode live",
    "test:opening-regression-fixtures:live:update": "tsx src/scripts/run-opening-regression-fixtures.ts --mode live --update-snapshots",
    "test:publish": "tsx src/scripts/test-publish.ts",
    "probe:vertex-imagen-contract": "tsx src/scripts/vertex-imagen-contract-probe.ts",
    "eval:continuity": "tsx src/scripts/run-continuity-evaluation.ts",
    "eval:continuity:health": "tsx src/scripts/check-continuity-eval-health.ts",
    "eval:continuity:preflight-env": "tsx src/scripts/preflight-continuity-env.ts",
    "eval:continuity:replay-planner": "tsx src/scripts/run-continuity-evaluation.ts --mode replay_planner",
    "eval:continuity:occupancy-only": "tsx src/scripts/run-continuity-evaluation.ts --mode occupancy_only",
    "eval:continuity:continuity-only": "tsx src/scripts/run-continuity-evaluation.ts --mode continuity_only",
    "eval:continuity:validator-only": "tsx src/scripts/run-continuity-evaluation.ts --mode validator_only"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^0.7.0",
    "@realenhance/shared": "workspace:*",
    "@types/node": "^20.11.30",
    "axios": "^1.13.2",
    "bullmq": "^5.9.0",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0",
    "opencv-ts": "^1.3.6",
    "pg": "^8.12.0",
    "pixelmatch": "^7.1.0",
    "redis": "^4.7.1",
    "replicate": "^1.3.1",
    "sharp": "^0.34.5"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.705.0",
    "@aws-sdk/s3-request-presigner": "^3.705.0"
  },
  "devDependencies": {
    "@types/form-data": "^2.5.0",
    "@types/jest": "^30.0.0",
    "@types/node-fetch": "^2.6.11",
    "@types/pg": "^8.15.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
