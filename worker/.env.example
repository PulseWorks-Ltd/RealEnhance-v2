# Worker Gemini configuration
# Copy values into your real worker environment. Do not commit live secrets.

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional: self-costing usage logs
# When these are set, [USAGE] logs include costEstimateUsd.
# If a model is missing pricing, costEstimateUsd will be null for that model.
#
# Variable format:
# GEMINI_PRICE_<MODEL>_INPUT_USD_PER_1M_TOKENS
# GEMINI_PRICE_<MODEL>_OUTPUT_USD_PER_1M_TOKENS
#
# Model normalization rule:
# - uppercase the model name
# - replace non-alphanumeric characters with underscores
#
# Examples:
# gemini-2.5-flash-image      -> GEMINI_2_5_FLASH_IMAGE
# gemini-3-pro-image-preview  -> GEMINI_3_PRO_IMAGE_PREVIEW
# gemini-2.5-flash            -> GEMINI_2_5_FLASH
# gemini-2.5-pro              -> GEMINI_2_5_PRO
# gemini-2.0-flash            -> GEMINI_2_0_FLASH

GEMINI_PRICE_GEMINI_2_5_FLASH_IMAGE_INPUT_USD_PER_1M_TOKENS=
GEMINI_PRICE_GEMINI_2_5_FLASH_IMAGE_OUTPUT_USD_PER_1M_TOKENS=

GEMINI_PRICE_GEMINI_3_PRO_IMAGE_PREVIEW_INPUT_USD_PER_1M_TOKENS=
GEMINI_PRICE_GEMINI_3_PRO_IMAGE_PREVIEW_OUTPUT_USD_PER_1M_TOKENS=

GEMINI_PRICE_GEMINI_2_5_FLASH_INPUT_USD_PER_1M_TOKENS=
GEMINI_PRICE_GEMINI_2_5_FLASH_OUTPUT_USD_PER_1M_TOKENS=

GEMINI_PRICE_GEMINI_2_5_PRO_INPUT_USD_PER_1M_TOKENS=
GEMINI_PRICE_GEMINI_2_5_PRO_OUTPUT_USD_PER_1M_TOKENS=

GEMINI_PRICE_GEMINI_2_0_FLASH_INPUT_USD_PER_1M_TOKENS=
GEMINI_PRICE_GEMINI_2_0_FLASH_OUTPUT_USD_PER_1M_TOKENS=