# Monorepo Docker ignores (safe for all services)
# Keep necessary packages and manifests available to Docker builds.

# VCS & logs
.git/
.gitignore
*.log
logs*
Validator Logs - *.txt

# Dependencies (each Dockerfile will run its own install)
node_modules/
.venv/
venv/

# Transient local artifacts
dist/
**/dist/
coverage/
**/coverage/
.pytest_cache/
__pycache__/
dump.rdb
attached_assets/

# External validator service source (not needed in worker/server images)
opencv-validator/

# DO NOT ignore these; worker and shared are needed by the worker Dockerfile
# client/
# worker/

# Keep lockfile to ensure reproducible installs
# pnpm-lock.yaml
